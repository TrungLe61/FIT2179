{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Australia's 20 Fastest Growing Local Government Areas (FY 2024–25)",
    "fontSize": 14,
    "fontWeight": "bold"
  },
  "width": "container",
  "height": 460,
  "data": {"url": "../data/population_lga_2024_25.csv"},
  "transform": [
    {"filter": "isValid(datum.change_pct) && datum.change_pct > 0"},
    {
      "window": [{"op": "rank", "as": "rank"}],
      "sort": [{"field": "change_pct", "order": "descending"}]
    },
    {"filter": "datum.rank <= 20"}
  ],
  "mark": {"type": "bar", "cornerRadiusEnd": 3},
  "encoding": {
    "y": {
      "field": "lga_name",
      "type": "nominal",
      "sort": {"field": "change_pct", "order": "descending"},
      "title": null,
      "axis": {"labelFontSize": 10}
    },
    "x": {
      "field": "change_pct",
      "type": "quantitative",
      "title": "Population Growth Rate (%)",
      "axis": {"format": ".1f", "grid": true}
    },
    "color": {
      "field": "state_abbr",
      "type": "nominal",
      "title": "State",
      "scale": {"scheme": "category10"},
      "legend": {"orient": "bottom-right", "labelFontSize": 10}
    },
    "tooltip": [
      {"field": "lga_name", "type": "nominal", "title": "LGA"},
      {"field": "state_abbr", "type": "nominal", "title": "State"},
      {"field": "change_pct", "type": "quantitative", "title": "Growth (%)", "format": ".2f"},
      {"field": "erp_2025", "type": "quantitative", "title": "Population (2025)", "format": ","}
    ]
  }
}
