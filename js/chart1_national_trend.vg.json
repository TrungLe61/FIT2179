{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "New Homes Approved to Be Built Each Month in Australia (1983–2026)",
    "fontSize": 14,
    "fontWeight": "bold"
  },
  "width": "container",
  "height": 280,
  "data": {"url": "data/approvals_national_monthly.csv"},
  "layer": [
    {
      "mark": {"type": "area", "opacity": 0.7, "interpolate": "monotone", "color": "#1976D2"},
      "encoding": {
        "x": {
          "field": "date", "type": "temporal",
          "axis": {"title": ""}
        },
        "y": {
          "field": "total", "type": "quantitative",
          "title": "New Homes Approved Per Month",
          "axis": {"format": ",.0f", "titleAngle": 0, "titleAlign": "left", "titleX": 0, "titleY": -10}
        },
        "tooltip": [
          {"field": "date", "type": "temporal", "title": "Month", "format": "%b %Y"},
          {"field": "total", "type": "quantitative", "title": "Total Approvals", "format": ","}
        ]
      }
    },
    {
      "description": "Callout pointer lines",
      "data": {
        "values": [
          {"ldate": "1997-06-01", "ly": 22000, "tdate": "2000-07-01", "ty": 10500},
          {"ldate": "2005-06-01", "ly": 22000, "tdate": "2008-09-01", "ty": 12000},
          {"ldate": "2014-06-01", "ly": 22000, "tdate": "2012-06-01", "ty": 14500},
          {"ldate": "2017-06-01", "ly": 19000, "tdate": "2020-03-01", "ty": 13500},
          {"ldate": "2023-01-01", "ly": 22000, "tdate": "2020-10-01", "ty": 20000},
          {"ldate": "2025-01-01", "ly": 19000, "tdate": "2022-05-01", "ty": 18500}
        ]
      },
      "mark": {"type": "rule", "color": "#aaa", "strokeWidth": 1},
      "encoding": {
        "x":  {"field": "ldate", "type": "temporal"},
        "y":  {"field": "ly",    "type": "quantitative"},
        "x2": {"field": "tdate", "type": "temporal"},
        "y2": {"field": "ty",    "type": "quantitative"}
      }
    },
    {
      "description": "Callout label text",
      "data": {
        "values": [
          {"ldate": "1997-06-01", "ly": 22000, "label": "GST Introduced\n(July 2000)",         "anchor": "center"},
          {"ldate": "2005-06-01", "ly": 22000, "label": "Global Financial\nCrisis (2008)",      "anchor": "center"},
          {"ldate": "2014-06-01", "ly": 22000, "label": "2012 Resources\nBoom",                 "anchor": "center"},
          {"ldate": "2017-06-01", "ly": 19000, "label": "COVID 19",                             "anchor": "center"},
          {"ldate": "2023-01-01", "ly": 22000, "label": "HomeBuilder\nGrant",                   "anchor": "center"},
          {"ldate": "2025-01-01", "ly": 19000, "label": "Rate Rises Slow\nThings Down",         "anchor": "center"}
        ]
      },
      "mark": {"type": "text", "align": "center", "fontSize": 12, "fontWeight": "bold", "color": "#1a1a1a", "lineBreak": "\n"},
      "encoding": {
        "x":    {"field": "ldate", "type": "temporal"},
        "y":    {"field": "ly",    "type": "quantitative"},
        "text": {"field": "label"}
      }
    }
  ],
  "config": {
    "title": {"font": "Open Sans", "fontSize": 14, "fontWeight": "bold"},
    "axis": {"labelFont": "Open Sans", "titleFont": "Open Sans", "labelFontSize": 11},
    "legend": {"labelFont": "Open Sans", "titleFont": "Open Sans"},
    "view": {"stroke": "transparent"}
  }
}
