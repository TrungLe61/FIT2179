{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Australia's Building Approvals: 40 Years of Booms and Busts (1983–2026)",
    "fontSize": 14,
    "fontWeight": "bold"
  },
  "width": "container",
  "height": 280,
  "data": {"url": "data/approvals_national_monthly.csv"},
  "layer": [
    {
      "transform": [
        {"fold": ["houses", "non_houses"], "as": ["type", "approvals"]},
        {"calculate": "datum.type === 'houses' ? 'Houses' : 'Apartments / Other'", "as": "dwelling_type"}
      ],
      "mark": {"type": "area", "opacity": 0.7, "interpolate": "monotone"},
      "encoding": {
        "x": {
          "field": "date", "type": "temporal",
          "axis": {"title": ""}
        },
        "y": {
          "field": "approvals", "type": "quantitative",
          "title": "Monthly Approvals",
          "stack": true,
          "axis": {"format": ","}
        },
        "color": {
          "field": "dwelling_type", "type": "nominal",
          "scale": {"domain": ["Houses", "Apartments / Other"], "range": ["#1976D2", "#FF7043"]},
          "legend": {"title": null, "orient": "top-left"}
        },
        "tooltip": [
          {"field": "date", "type": "temporal", "title": "Month", "format": "%b %Y"},
          {"field": "dwelling_type", "type": "nominal", "title": "Type"},
          {"field": "approvals", "type": "quantitative", "title": "Approvals", "format": ","}
        ]
      }
    },
    {
      "data": {
        "values": [
          {"date": "2008-09-01", "label": "2008 Financial Crisis"},
          {"date": "2012-06-01", "label": "Mining Boom Peak"},
          {"date": "2020-03-01", "label": "COVID-19"},
          {"date": "2022-05-01", "label": "Rate Hikes Begin"}
        ]
      },
      "layer": [
        {
          "mark": {"type": "rule", "strokeDash": [4, 4], "color": "#999", "strokeWidth": 1},
          "encoding": {
            "x": {"field": "date", "type": "temporal"}
          }
        },
        {
          "mark": {"type": "text", "align": "left", "dx": 4, "dy": -8, "fontSize": 10, "fontStyle": "italic", "color": "#666"},
          "encoding": {
            "x": {"field": "date", "type": "temporal"},
            "y": {"value": 20},
            "text": {"field": "label"}
          }
        }
      ]
    }
  ],
  "config": {
    "title": {"font": "Open Sans", "fontSize": 14, "fontWeight": "bold"},
    "axis": {"labelFont": "Open Sans", "titleFont": "Open Sans", "labelFontSize": 11},
    "legend": {"labelFont": "Open Sans", "titleFont": "Open Sans"},
    "view": {"stroke": "transparent"}
  }
}
