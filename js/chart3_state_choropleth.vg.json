{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Building Approvals by State (FY 2024–25)",
    "subtitle": "Select a state — circle colour shows approvals per 1,000 residents; regions shaded by population growth",
    "subtitleFontStyle": "italic",
    "subtitleFontSize": 11,
    "subtitleColor": "#666",
    "fontSize": 14,
    "fontWeight": "bold"
  },
  "width": "container",
  "height": 500,
  "params": [
    {
      "name": "selected_state",
      "value": "New South Wales",
      "bind": {
        "input": "select",
        "options": [
          "New South Wales", "Victoria", "Queensland",
          "Western Australia", "South Australia", "Tasmania",
          "Northern Territory", "Australian Capital Territory"
        ],
        "labels": [
          "New South Wales", "Victoria", "Queensland",
          "Western Australia", "South Australia", "Tasmania",
          "Northern Territory", "ACT"
        ],
        "name": "State: "
      }
    }
  ],
  "projection": {
    "type": "mercator",
    "scale": {
      "expr": "{'New South Wales':6000,'Victoria':4000,'Queensland':5000,'Western Australia':4000,'South Australia':5000,'Tasmania':6500,'Northern Territory':4500,'Australian Capital Territory':38000}[selected_state]"
    },
    "center": {
      "expr": "{'New South Wales':[151.0,-33.3],'Victoria':[145.5,-37.5],'Queensland':[152.7,-27.3],'Western Australia':[116.9,-32.9],'South Australia':[139.0,-35.2],'Tasmania':[146.7,-42.1],'Northern Territory':[131.5,-13.0],'Australian Capital Territory':[149.1,-35.3]}[selected_state]"
    }
  },
  "layer": [
    {
      "description": "Selected state boundary (base fill)",
      "data": {
        "url": "topojson/aus-states-topo.json",
        "format": {"type": "topojson", "feature": "aus_states"}
      },
      "transform": [
        {"filter": "datum.properties.STATE_NAME === selected_state"}
      ],
      "mark": {"type": "geoshape", "fill": "#e8f0f8", "stroke": "#5a8fc2", "strokeWidth": 2}
    },
    {
      "description": "SA4 regional population growth choropleth",
      "data": {
        "url": "topojson/aus-sa4-topo.json",
        "format": {"type": "topojson", "feature": "data"}
      },
      "transform": [
        {"filter": "datum.properties.state === selected_state"},
        {
          "lookup": "properties.sa4_name",
          "from": {
            "data": {"url": "data/sa4_population.csv"},
            "key": "sa4_name",
            "fields": ["growth_pct", "total_pop", "total_change", "lga_count"]
          }
        },
        {"calculate": "isValid(datum.growth_pct) ? datum.growth_pct : 0", "as": "growth_pct_filled"}
      ],
      "mark": {"type": "geoshape", "stroke": "white", "strokeWidth": 0.6},
      "encoding": {
        "color": {
          "field": "growth_pct_filled",
          "type": "quantitative",
          "title": "Pop. growth (% per year)",
          "scale": {"scheme": "greens", "domain": [0, 4]},
          "legend": {"orient": "bottom-right", "format": ".1f"}
        },
        "tooltip": [
          {"field": "properties.sa4_name", "type": "nominal", "title": "Region"},
          {"field": "growth_pct", "type": "quantitative", "title": "Pop. growth (% per year)", "format": ".2f"},
          {"field": "total_pop", "type": "quantitative", "title": "Population 2025", "format": ","},
          {"field": "total_change", "type": "quantitative", "title": "Pop. change (2024→25)", "format": ","}
        ]
      }
    },
    {
      "description": "Capital city circle",
      "data": {"url": "data/gccsa_summary.csv"},
      "transform": [
        {
          "calculate": "{'ACT':'Australian Capital Territory','Adelaide':'South Australia','Brisbane':'Queensland','Darwin':'Northern Territory','Hobart':'Tasmania','Melbourne':'Victoria','Perth':'Western Australia','Sydney':'New South Wales'}[datum.city]",
          "as": "state_name"
        },
        {"filter": "datum.state_name === selected_state"}
      ],
      "mark": {"type": "circle", "size": 1800, "opacity": 0.85, "stroke": "white", "strokeWidth": 1.5},
      "encoding": {
        "longitude": {"field": "lon", "type": "quantitative"},
        "latitude": {"field": "lat", "type": "quantitative"},
        "color": {
          "field": "approvals_per_1000",
          "type": "quantitative",
          "title": "Per 1,000 residents",
          "scale": {"scheme": "oranges", "domain": [2, 10]},
          "legend": null
        },
        "tooltip": [
          {"field": "city_name", "type": "nominal", "title": "City"},
          {"field": "total", "type": "quantitative", "title": "Total Approvals FY24-25", "format": ","},
          {"field": "houses", "type": "quantitative", "title": "Houses", "format": ","},
          {"field": "non_houses", "type": "quantitative", "title": "Apartments / Other", "format": ","},
          {"field": "approvals_per_1000", "type": "quantitative", "title": "Per 1,000 residents", "format": ".2f"},
          {"field": "pop_growth_pct", "type": "quantitative", "title": "Pop. growth (% per year)", "format": ".2f"}
        ]
      }
    },
    {
      "description": "City name label",
      "data": {"url": "data/gccsa_summary.csv"},
      "transform": [
        {
          "calculate": "{'ACT':'Australian Capital Territory','Adelaide':'South Australia','Brisbane':'Queensland','Darwin':'Northern Territory','Hobart':'Tasmania','Melbourne':'Victoria','Perth':'Western Australia','Sydney':'New South Wales'}[datum.city]",
          "as": "state_name"
        },
        {"filter": "datum.state_name === selected_state"},
        {
          "calculate": "datum.city === 'ACT' ? 'Canberra' : replace(datum.city_name, 'Greater ', '')",
          "as": "short_name"
        }
      ],
      "mark": {
        "type": "text",
        "dy": -22,
        "fontSize": 13,
        "fontWeight": "bold",
        "color": "#1a1a2e"
      },
      "encoding": {
        "longitude": {"field": "lon", "type": "quantitative"},
        "latitude": {"field": "lat", "type": "quantitative"},
        "text": {"field": "short_name", "type": "nominal"}
      }
    },
    {
      "description": "Total approvals annotation below city name",
      "data": {"url": "data/gccsa_summary.csv"},
      "transform": [
        {
          "calculate": "{'ACT':'Australian Capital Territory','Adelaide':'South Australia','Brisbane':'Queensland','Darwin':'Northern Territory','Hobart':'Tasmania','Melbourne':'Victoria','Perth':'Western Australia','Sydney':'New South Wales'}[datum.city]",
          "as": "state_name"
        },
        {"filter": "datum.state_name === selected_state"},
        {"calculate": "format(datum.total, ',') + ' approvals'", "as": "approvals_label"}
      ],
      "mark": {
        "type": "text",
        "dy": 28,
        "fontSize": 11,
        "fontWeight": "normal",
        "color": "#333"
      },
      "encoding": {
        "longitude": {"field": "lon", "type": "quantitative"},
        "latitude": {"field": "lat", "type": "quantitative"},
        "text": {"field": "approvals_label", "type": "nominal"}
      }
    }
  ],
  "config": {
    "title": {"font": "Open Sans", "fontSize": 14, "fontWeight": "bold"},
    "axis": {"labelFont": "Open Sans", "titleFont": "Open Sans", "labelFontSize": 11},
    "legend": {"labelFont": "Open Sans", "titleFont": "Open Sans"},
    "view": {"stroke": "transparent"}
  }
}
