{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Which States Are Keeping Up? Population Growth vs Building Supply",
    "fontSize": 14,
    "fontWeight": "bold"
  },
  "width": "container",
  "height": 340,
  "data": {"url": "data/state_summary.csv"},
  "transform": [
    {"filter": "isValid(datum.approvals_per_1000) && isValid(datum.pop_growth_pct)"}
  ],
  "params": [
    {
      "name": "state_highlight",
      "bind": {
        "input": "select",
        "options": [null, "NSW", "VIC", "QLD", "WA", "SA", "TAS", "NT", "ACT"],
        "labels": ["Show All", "NSW", "VIC", "QLD", "WA", "SA", "TAS", "NT", "ACT"],
        "name": "Highlight State: "
      }
    }
  ],
  "layer": [
    {
      "mark": {"type": "rule", "color": "#ccc", "strokeDash": [4, 4]},
      "encoding": {"x": {"datum": 1.8}}
    },
    {
      "mark": {"type": "rule", "color": "#ccc", "strokeDash": [4, 4]},
      "encoding": {"y": {"datum": 5.8}}
    },
    {
      "mark": {"type": "circle"},
      "encoding": {
        "x": {
          "field": "pop_growth_pct",
          "type": "quantitative",
          "title": "Population Growth Rate (%)",
          "scale": {"domain": [0, 3]},
          "axis": {"grid": false}
        },
        "y": {
          "field": "approvals_per_1000",
          "type": "quantitative",
          "title": "Approvals per 1,000 People",
          "axis": {"grid": false}
        },
        "size": {
          "field": "pop_2025",
          "type": "quantitative",
          "title": "Population (2025)",
          "scale": {
            "type": "threshold",
            "domain": [500000, 1000000, 3000000, 6000000],
            "range": [50, 150, 300, 500, 800]
          },
          "legend": {"format": ","}
        },
        "color": {
          "field": "state_name",
          "type": "nominal",
          "legend": null
        },
        "opacity": {
          "condition": {"test": "state_highlight == null || datum.state == state_highlight", "value": 0.85},
          "value": 0.1
        },
        "tooltip": [
          {"field": "state_name", "type": "nominal", "title": "State"},
          {"field": "pop_growth_pct", "type": "quantitative", "title": "Pop. growth (%)", "format": ".2f"},
          {"field": "approvals_per_1000", "type": "quantitative", "title": "Approvals per 1,000", "format": ".2f"},
          {"field": "pop_2025", "type": "quantitative", "title": "Population (2025)", "format": ","}
        ]
      }
    },
    {
      "mark": {"type": "text", "dy": -12, "fontSize": 11, "fontWeight": "bold"},
      "encoding": {
        "x": {"field": "pop_growth_pct", "type": "quantitative"},
        "y": {"field": "approvals_per_1000", "type": "quantitative"},
        "text": {"field": "state", "type": "nominal"},
        "color": {"value": "#333"}
      }
    }
  ],
  "config": {
    "title": {"font": "Open Sans", "fontSize": 14, "fontWeight": "bold"},
    "axis": {"labelFont": "Open Sans", "titleFont": "Open Sans", "labelFontSize": 11},
    "legend": {"labelFont": "Open Sans", "titleFont": "Open Sans"},
    "view": {"stroke": "transparent"}
  }
}
