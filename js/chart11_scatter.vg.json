{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "How Each State's Approvals Compare to What Its Population Actually Needed (2024–25)",
    "subtitle": "Dots above the diagonal line = built more than needed. Dots below = didn't build enough.",
    "subtitleFontStyle": "italic",
    "subtitleFontSize": 11,
    "subtitleColor": "#666",
    "fontSize": 14,
    "fontWeight": "bold"
  },
  "width": 500,
  "height": 450,
  "layer": [
    {
      "description": "Diagonal reference line (y = x)",
      "data": {"values": [{"ref_x": 0, "ref_y": 0}, {"ref_x": 58000, "ref_y": 58000}]},
      "mark": {"type": "line", "color": "#aaa", "strokeDash": [5, 4], "strokeWidth": 1.5},
      "encoding": {
        "x": {"field": "ref_x", "type": "quantitative"},
        "y": {"field": "ref_y", "type": "quantitative"}
      }
    },
    {
      "description": "Reference line label",
      "data": {"values": [{"ref_x": 42000, "ref_y": 45000, "label": "Supply = Demand"}]},
      "mark": {"type": "text", "fontSize": 10, "color": "#999", "fontStyle": "italic", "angle": -50},
      "encoding": {
        "x": {"field": "ref_x", "type": "quantitative"},
        "y": {"field": "ref_y", "type": "quantitative"},
        "text": {"field": "label"}
      }
    },
    {
      "description": "Bubbles",
      "data": {"url": "data/state_summary.csv"},
      "transform": [
        {"filter": "isValid(datum.pop_2024) && isValid(datum.pop_2025)"},
        {"calculate": "datum.pop_2025 - datum.pop_2024", "as": "pop_growth"},
        {"calculate": "datum.pop_growth / 2.5", "as": "needed_dwellings"},
        {"calculate": "round(datum.needed_dwellings)", "as": "needed_rounded"},
        {"calculate": "datum.approvals_fy2425 >= datum.needed_dwellings ? 'Surplus' : 'Deficit'", "as": "gap_status"},
        {"calculate": "datum.approvals_fy2425 - datum.needed_dwellings", "as": "dwelling_gap"}
      ],
      "mark": {"type": "point", "filled": true, "opacity": 0.85, "stroke": "white", "strokeWidth": 1},
      "encoding": {
        "x": {
          "field": "needed_dwellings",
          "type": "quantitative",
          "title": "How Many New Homes Were Actually Needed",
          "axis": {"format": ",.0f"},
          "scale": {"domain": [0, 58000]}
        },
        "y": {
          "field": "approvals_fy2425",
          "type": "quantitative",
          "title": "How Many New Homes Were Approved",
          "axis": {"format": ",.0f"},
          "scale": {"domain": [0, 58000]}
        },
        "size": {
          "field": "pop_2025",
          "type": "quantitative",
          "scale": {"domain": [200000, 8000000], "range": [80, 2500]},
          "legend": {
            "title": "State population size (2025)",
            "values": [500000, 2000000, 5000000, 8000000],
            "labelExpr": "datum.value < 2000000 ? '< 2M' : datum.value < 5000000 ? '2M – 5M' : datum.value < 8000000 ? '5M – 8M' : '≥ 8M'",
            "orient": "top-left"
          }
        },
        "color": {
          "field": "gap_status",
          "type": "nominal",
          "scale": {"domain": ["Surplus", "Deficit"], "range": ["#1976D2", "#C62828"]},
          "legend": null
        },
        "tooltip": [
          {"field": "state_name", "type": "nominal", "title": "State"},
          {"field": "approvals_fy2425", "type": "quantitative", "title": "Approvals", "format": ","},
          {"field": "pop_growth", "type": "quantitative", "title": "New residents", "format": ","},
          {"field": "needed_rounded", "type": "quantitative", "title": "Dwellings needed", "format": ","},
          {"field": "dwelling_gap", "type": "quantitative", "title": "Surplus/deficit", "format": "+,.0f"},
          {"field": "gap_status", "type": "nominal", "title": "Status"}
        ]
      }
    },
    {
      "description": "State abbreviation labels",
      "data": {"url": "data/state_summary.csv"},
      "transform": [
        {"filter": "isValid(datum.pop_2024) && isValid(datum.pop_2025)"},
        {"calculate": "datum.pop_2025 - datum.pop_2024", "as": "pop_growth"},
        {"calculate": "datum.pop_growth / 2.5", "as": "needed_dwellings"},
        {"calculate": "datum.approvals_fy2425 >= datum.needed_dwellings ? 'Surplus' : 'Deficit'", "as": "gap_status"}
      ],
      "mark": {
        "type": "text",
        "fontSize": 11,
        "fontWeight": "600",
        "dy": {"expr": "datum.state === 'VIC' ? 40 : datum.state === 'QLD' ? 36 : datum.state === 'WA' ? 30 : datum.state === 'TAS' ? -20 : datum.state === 'NT' ? 16 : datum.state === 'ACT' ? -20 : datum.state === 'NSW' ? -36 : -22"},
        "dx": {"expr": "datum.state === 'NT' ? 6 : 0"}
      },
      "encoding": {
        "x": {"field": "needed_dwellings", "type": "quantitative"},
        "y": {"field": "approvals_fy2425", "type": "quantitative"},
        "text": {"field": "state", "type": "nominal"},
        "color": {
          "field": "gap_status",
          "type": "nominal",
          "scale": {"domain": ["Surplus", "Deficit"], "range": ["#1976D2", "#C62828"]},
          "legend": null
        }
      }
    }
  ],
  "config": {
    "title": {"font": "Open Sans", "fontSize": 14, "fontWeight": "bold"},
    "axis": {"labelFont": "Open Sans", "titleFont": "Open Sans", "labelFontSize": 11},
    "legend": {"labelFont": "Open Sans", "titleFont": "Open Sans", "symbolFillColor": "#aaa", "symbolStrokeColor": "#aaa"},
    "view": {"stroke": "transparent"}
  }
}
