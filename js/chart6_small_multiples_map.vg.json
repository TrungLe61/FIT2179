{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "State Housing Metrics at a Glance",
    "fontSize": 14,
    "fontWeight": "bold"
  },
  "repeat": ["approvals_fy2425", "approvals_per_1000", "yoy_change_pct"],
  "columns": 3,
  "spacing": 10,
  "spec": {
    "width": 120,
    "height": 100,
    "data": {
      "url": "topojson/aus-states-topo.json",
      "format": {"type": "topojson", "feature": "aus_states"}
    },
    "transform": [
      {
        "lookup": "properties.STATE_NAME",
        "from": {
          "data": {"url": "data/state_summary.csv"},
          "key": "state_name",
          "fields": ["state_name", "approvals_fy2425", "approvals_per_1000", "yoy_change_pct"]
        }
      }
    ],
    "projection": {"type": "mercator", "center": [134, -28], "scale": 112},
    "mark": {"type": "geoshape", "stroke": "white", "strokeWidth": 1},
    "encoding": {
      "color": {
        "field": {"repeat": "repeat"},
        "type": "quantitative",
        "scale": {"scheme": "blues"},
        "legend": {"format": ".2s", "title": null}
      },
      "tooltip": [
        {"field": "state_name", "type": "nominal", "title": "State"},
        {"field": {"repeat": "repeat"}, "type": "quantitative", "format": ".2f"}
      ]
    }
  },
  "config": {
    "title": {"font": "Open Sans", "fontSize": 14, "fontWeight": "bold"},
    "axis": {"labelFont": "Open Sans", "titleFont": "Open Sans", "labelFontSize": 11},
    "legend": {"labelFont": "Open Sans", "titleFont": "Open Sans"},
    "view": {"stroke": "transparent"}
  }
}
