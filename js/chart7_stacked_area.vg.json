{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Composition of Approvals: Houses vs Apartments (1983–2026)",
    "fontSize": 14,
    "fontWeight": "bold"
  },
  "width": "container",
  "height": 300,
  "data": {"url": "data/approvals_national_monthly.csv"},
  "transform": [
    {"fold": ["houses", "non_houses"], "as": ["type", "approvals"]},
    {"calculate": "datum.type === 'houses' ? 'Standalone Houses' : 'Apartments, Units & Townhouses'", "as": "dwelling_type"}
  ],
  "mark": {"type": "area", "opacity": 0.8, "interpolate": "monotone"},
  "encoding": {
    "x": {
      "field": "date", "type": "temporal",
      "axis": {"title": ""}
    },
    "y": {
      "field": "approvals", "type": "quantitative",
      "stack": true,
      "title": "Monthly Approvals",
      "axis": {"format": ",.0f"}
    },
    "color": {
      "field": "dwelling_type", "type": "nominal",
      "scale": {"domain": ["Standalone Houses", "Apartments, Units & Townhouses"], "range": ["#1976D2", "#FF7043"]},
      "legend": {"title": null, "orient": "top-left"}
    },
    "tooltip": [
      {"field": "date", "type": "temporal", "title": "Month", "format": "%b %Y"},
      {"field": "dwelling_type", "type": "nominal", "title": "Type"},
      {"field": "approvals", "type": "quantitative", "title": "Approvals", "format": ","}
    ]
  },
  "config": {
    "title": {"font": "Open Sans", "fontSize": 14, "fontWeight": "bold"},
    "axis": {"labelFont": "Open Sans", "titleFont": "Open Sans", "labelFontSize": 11},
    "legend": {"labelFont": "Open Sans", "titleFont": "Open Sans"},
    "view": {"stroke": "transparent"}
  }
}
