{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Housing Mix by Capital City: Houses vs Apartments",
    "fontSize": 14,
    "fontWeight": "bold"
  },
  "width": "container",
  "height": 280,
  "data": {"url": "data/gccsa_summary.csv"},
  "transform": [
    {
      "calculate": "datum.city_name === 'Australian Capital Territory' ? 'Canberra (ACT)' : replace(datum.city_name, 'Greater ', '')",
      "as": "short_name"
    },
    {"fold": ["houses", "non_houses"], "as": ["type", "count"]},
    {
      "calculate": "datum.type === 'houses' ? 'Houses' : 'Apartments / Other'",
      "as": "dwelling_type"
    }
  ],
  "mark": "bar",
  "encoding": {
    "y": {
      "field": "short_name",
      "type": "nominal",
      "sort": {"field": "house_pct", "op": "max", "order": "descending"},
      "title": null,
      "axis": {"labelFontSize": 11}
    },
    "x": {
      "field": "count",
      "type": "quantitative",
      "stack": "normalize",
      "title": "Share of Approvals",
      "axis": {"format": "%"}
    },
    "color": {
      "field": "dwelling_type",
      "type": "nominal",
      "title": "Dwelling Type",
      "scale": {
        "domain": ["Houses", "Apartments / Other"],
        "range": ["#1976D2", "#FF7043"]
      },
      "legend": {"orient": "top-right"}
    },
    "order": {"field": "type", "sort": "ascending"},
    "tooltip": [
      {"field": "short_name", "type": "nominal", "title": "City"},
      {"field": "dwelling_type", "title": "Type"},
      {"field": "count", "type": "quantitative", "title": "Approvals", "format": ","},
      {"field": "house_pct", "type": "quantitative", "title": "House %", "format": ".1f"}
    ]
  },
  "config": {
    "title": {"font": "Open Sans", "fontSize": 14, "fontWeight": "bold"},
    "axis": {"labelFont": "Open Sans", "titleFont": "Open Sans", "labelFontSize": 11},
    "legend": {"labelFont": "Open Sans", "titleFont": "Open Sans"},
    "view": {"stroke": "transparent"}
  }
}
