{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Building Rate by Capital City (FY 2024–25)",
    "subtitle": "New dwellings approved per 1,000 residents",
    "subtitleFontStyle": "italic",
    "subtitleFontSize": 11,
    "subtitleColor": "#666",
    "fontSize": 14,
    "fontWeight": "bold"
  },
  "width": "container",
  "height": 320,
  "data": {"url": "data/gccsa_summary.csv"},
  "transform": [
    {
      "calculate": "datum.city === 'ACT' ? 'Canberra' : replace(datum.city_name, 'Greater ', '')",
      "as": "short_name"
    }
  ],
  "layer": [
    {
      "mark": {"type": "bar", "cornerRadiusEnd": 4},
      "encoding": {
        "y": {
          "field": "short_name",
          "type": "nominal",
          "sort": "-x",
          "title": "",
          "axis": {"labelFontSize": 12}
        },
        "x": {
          "field": "approvals_per_1000",
          "type": "quantitative",
          "title": "Approvals per 1,000 residents",
          "axis": {"format": ".1f", "grid": true}
        },
        "color": {
          "field": "approvals_per_1000",
          "type": "quantitative",
          "scale": {"scheme": "oranges", "domain": [2, 10]},
          "legend": null
        },
        "tooltip": [
          {"field": "short_name", "type": "nominal", "title": "City"},
          {"field": "approvals_per_1000", "type": "quantitative", "title": "Per 1,000 residents", "format": ".2f"},
          {"field": "total", "type": "quantitative", "title": "Total Approvals FY24-25", "format": ","},
          {"field": "pop_growth_pct", "type": "quantitative", "title": "Pop. growth (%)", "format": ".2f"}
        ]
      }
    },
    {
      "mark": {"type": "text", "align": "left", "dx": 5, "fontSize": 11, "color": "#333"},
      "encoding": {
        "y": {"field": "short_name", "type": "nominal", "sort": "-x"},
        "x": {"field": "approvals_per_1000", "type": "quantitative"},
        "text": {"field": "approvals_per_1000", "type": "quantitative", "format": ".2f"}
      }
    }
  ],
  "config": {
    "title": {"font": "Open Sans", "fontSize": 14, "fontWeight": "bold"},
    "axis": {"labelFont": "Open Sans", "titleFont": "Open Sans", "labelFontSize": 11},
    "legend": {"labelFont": "Open Sans", "titleFont": "Open Sans"},
    "view": {"stroke": "transparent"}
  }
}
