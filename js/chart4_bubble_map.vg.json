{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "New Homes Approved Per 1,000 Residents, by State (2024–25)",
    "subtitle": "For every 1,000 people living in that state, how many new homes were approved",
    "subtitleFontStyle": "italic",
    "subtitleFontSize": 11,
    "subtitleColor": "#666",
    "fontSize": 14,
    "fontWeight": "bold"
  },
  "width": "container",
  "height": 320,
  "data": {"url": "data/state_summary.csv"},
  "transform": [
    {
      "calculate": "datum.state === 'ACT' ? 'ACT' : datum.state_name",
      "as": "display_name"
    }
  ],
  "layer": [
    {
      "mark": {"type": "bar", "cornerRadiusEnd": 4},
      "encoding": {
        "y": {
          "field": "display_name",
          "type": "nominal",
          "sort": "-x",
          "title": "",
          "axis": {"labelFontSize": 12}
        },
        "x": {
          "field": "approvals_per_1000",
          "type": "quantitative",
          "title": "New Homes Approved Per 1,000 People",
          "scale": {"domainMax": 11},
          "axis": {"format": ".1f", "grid": true}
        },
        "color": {
          "field": "approvals_per_1000",
          "type": "quantitative",
          "scale": {"scheme": "oranges", "domain": [2, 10]},
          "legend": null
        },
        "tooltip": [
          {"field": "display_name", "type": "nominal", "title": "State"},
          {"field": "approvals_per_1000", "type": "quantitative", "title": "Per 1,000 residents", "format": ".2f"},
          {"field": "approvals_fy2425", "type": "quantitative", "title": "Total Approvals FY24-25", "format": ","},
          {"field": "pop_growth_pct", "type": "quantitative", "title": "Pop. growth (%)", "format": ".2f"}
        ]
      }
    },
    {
      "mark": {"type": "text", "align": "left", "dx": 5, "fontSize": 11, "color": "#333"},
      "encoding": {
        "y": {"field": "display_name", "type": "nominal", "sort": "-x"},
        "x": {"field": "approvals_per_1000", "type": "quantitative"},
        "text": {"field": "approvals_per_1000", "type": "quantitative", "format": ".2f"}
      }
    },
    {
      "description": "NSW callout line",
      "data": {"values": [{"x1": 5.76, "x2": 7.2}]},
      "mark": {"type": "rule", "color": "#888", "strokeWidth": 1},
      "encoding": {
        "x":  {"field": "x1", "type": "quantitative"},
        "y":  {"datum": "New South Wales"},
        "x2": {"field": "x2"},
        "y2": {"datum": "ACT"}
      }
    },
    {
      "description": "NSW callout text",
      "data": {"values": [{"x": 7.2, "label": "Despite having Australia's 2nd-largest\npopulation, NSW approves far fewer\nhomes per person than Victoria or SA,\nsuggesting it's not building fast enough."}]},
      "mark": {"type": "text", "align": "left", "dx": 5, "fontSize": 10, "color": "#444", "lineBreak": "\n", "fontStyle": "italic"},
      "encoding": {
        "x": {"field": "x", "type": "quantitative"},
        "y": {"datum": "ACT"},
        "text": {"field": "label"}
      }
    }
  ],
  "config": {
    "title": {"font": "Open Sans", "fontSize": 14, "fontWeight": "bold"},
    "axis": {"labelFont": "Open Sans", "titleFont": "Open Sans", "labelFontSize": 11},
    "legend": {"labelFont": "Open Sans", "titleFont": "Open Sans"},
    "view": {"stroke": "transparent"}
  }
}
