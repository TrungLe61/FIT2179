{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Year-on-Year Change in Building Approvals by State (FY23–24 vs FY24–25)",
    "fontSize": 14,
    "fontWeight": "bold"
  },
  "width": 415,
  "height": 260,
  "projection": {"type": "mercator", "center": [134, -26], "scale": 440},
  "data": {
    "url": "topojson/aus-states-topo.json",
    "format": {"type": "topojson", "feature": "aus_states"}
  },
  "transform": [
    {
      "lookup": "properties.STATE_NAME",
      "from": {
        "data": {"url": "data/state_summary.csv"},
        "key": "state_name",
        "fields": ["state_name", "yoy_change_pct", "approvals_fy2425", "approvals_fy2324"]
      }
    }
  ],
  "mark": {"type": "geoshape", "stroke": "white", "strokeWidth": 2},
  "encoding": {
    "color": {
      "field": "yoy_change_pct",
      "type": "quantitative",
      "title": "YoY Change %",
      "scale": {"domainMid": 0, "scheme": "blueorange", "reverse": true},
      "legend": {"format": ".1f", "title": "YoY Change (%)"}
    },
    "tooltip": [
      {"field": "state_name", "type": "nominal", "title": "State"},
      {"field": "yoy_change_pct", "type": "quantitative", "title": "YoY Change (%)", "format": ".1f"},
      {"field": "approvals_fy2425", "type": "quantitative", "title": "Approvals FY24–25", "format": ","},
      {"field": "approvals_fy2324", "type": "quantitative", "title": "Approvals FY23–24", "format": ","}
    ]
  },
  "config": {
    "title": {"font": "Open Sans", "fontSize": 14, "fontWeight": "bold"},
    "axis": {"labelFont": "Open Sans", "titleFont": "Open Sans", "labelFontSize": 11},
    "legend": {"labelFont": "Open Sans", "titleFont": "Open Sans"},
    "view": {"stroke": "transparent"}
  }
}
