{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Housing Adequacy Score by Capital City",
    "subtitle": "Score = actual approvals ÷ estimated need (ABS: 2.5 persons/dwelling). Score > 1 = meeting demand.",
    "subtitleFontStyle": "italic",
    "subtitleFontSize": 11,
    "subtitleColor": "#666",
    "fontSize": 14,
    "fontWeight": "bold"
  },
  "width": "container",
  "height": 300,
  "data": {"url": "data/gccsa_summary.csv"},
  "transform": [
    {
      "calculate": "datum.city === 'ACT' ? 'Canberra (ACT)' : replace(datum.city_name, 'Greater ', '')",
      "as": "short_name"
    },
    {
      "calculate": "(datum.pop_2025 - datum.pop_2024) / 2.5 / datum.pop_2025 * 1000",
      "as": "need_per_1000"
    },
    {
      "calculate": "datum.approvals_per_1000 / datum.need_per_1000",
      "as": "adequacy_score"
    }
  ],
  "layer": [
    {
      "description": "Reference line at 1.0 = meets demand",
      "mark": {"type": "rule", "color": "#333", "strokeDash": [5, 4], "strokeWidth": 1.5},
      "encoding": {"x": {"datum": 1}}
    },
    {
      "description": "Adequacy score bars",
      "mark": {"type": "bar", "cornerRadiusEnd": 4},
      "encoding": {
        "y": {
          "field": "short_name",
          "type": "nominal",
          "sort": {"field": "adequacy_score", "order": "descending"},
          "title": null,
          "axis": {"labelFontSize": 11}
        },
        "x": {
          "field": "adequacy_score",
          "type": "quantitative",
          "title": "Housing Adequacy Score (actual ÷ estimated need)",
          "axis": {"grid": true, "format": ".1f"},
          "scale": {"domain": [0, 5]}
        },
        "color": {
          "condition": {"test": "datum.adequacy_score >= 1", "value": "#2e7d32"},
          "value": "#c62828"
        },
        "tooltip": [
          {"field": "short_name", "type": "nominal", "title": "City"},
          {"field": "approvals_per_1000", "type": "quantitative", "title": "Actual (per 1,000)", "format": ".2f"},
          {"field": "need_per_1000", "type": "quantitative", "title": "Estimated Need (per 1,000)", "format": ".2f"},
          {"field": "adequacy_score", "type": "quantitative", "title": "Adequacy Score", "format": ".2f"}
        ]
      }
    },
    {
      "description": "Score value labels",
      "mark": {"type": "text", "align": "left", "dx": 5, "fontSize": 11, "color": "#333"},
      "encoding": {
        "y": {
          "field": "short_name",
          "type": "nominal",
          "sort": {"field": "adequacy_score", "order": "descending"}
        },
        "x": {"field": "adequacy_score", "type": "quantitative"},
        "text": {"field": "adequacy_score", "type": "quantitative", "format": ".2f"}
      }
    }
  ],
  "config": {
    "title": {"font": "Open Sans", "fontSize": 14, "fontWeight": "bold"},
    "axis": {"labelFont": "Open Sans", "titleFont": "Open Sans", "labelFontSize": 11},
    "legend": {"labelFont": "Open Sans", "titleFont": "Open Sans"},
    "view": {"stroke": "transparent"}
  }
}
