{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Total New Homes Approved Over the Years",
    "fontSize": 14,
    "fontWeight": "bold"
  },
  "width": "container",
  "height": 280,
  "layer": [
    {
      "data": {"url": "data/approvals_national_monthly.csv"},
      "transform": [
        {
          "window": [{"op": "sum", "field": "total", "as": "rolling_12m"}],
          "frame": [-11, 0],
          "sort": [{"field": "date", "order": "ascending"}]
        },
        {"filter": "datum.rolling_12m != null && datum.rolling_12m > 0"}
      ],
      "mark": {"type": "bar", "color": "#90CAF9"},
      "encoding": {
        "x": {
          "field": "date",
          "type": "temporal",
          "title": null,
          "axis": {"grid": false, "labelAngle": 0}
        },
        "y": {
          "field": "rolling_12m",
          "type": "quantitative",
          "title": "Homes Approved",
          "axis": {"format": ",.0f"}
        },
        "tooltip": [
          {"field": "date", "type": "temporal", "title": "Month", "format": "%b %Y"},
          {"field": "rolling_12m", "type": "quantitative", "title": "Rolling 12-month total", "format": ","}
        ]
      }
    },
    {
      "data": {"values": [{}]},
      "mark": {"type": "rule", "color": "#C62828", "strokeWidth": 2.5, "strokeDash": [6, 3]},
      "encoding": {"y": {"datum": 240000}}
    },
    {
      "description": "Callout pointer line to 2016 peak",
      "data": {"values": [{"ldate": "2012-01-01", "ly": 170000, "tdate": "2016-06-01", "ty": 240000}]},
      "mark": {"type": "rule", "color": "#aaa", "strokeWidth": 1},
      "encoding": {
        "x":  {"field": "ldate", "type": "temporal"},
        "y":  {"field": "ly",    "type": "quantitative"},
        "x2": {"field": "tdate", "type": "temporal"},
        "y2": {"field": "ty",    "type": "quantitative"}
      }
    },
    {
      "description": "Callout label for 2016 peak",
      "data": {"values": [{"ldate": "2012-01-01", "ly": 170000, "label": "Last time approvals\nreached the 240k target"}]},
      "mark": {"type": "text", "align": "center", "fontSize": 11, "color": "#333", "lineBreak": "\n"},
      "encoding": {
        "x":    {"field": "ldate", "type": "temporal"},
        "y":    {"field": "ly",    "type": "quantitative"},
        "text": {"field": "label"}
      }
    },
    {
      "data": {"values": [{"label": "Government's yearly goal: 240,000 homes"}]},
      "mark": {
        "type": "text",
        "align": "left",
        "dx": 6,
        "dy": -6,
        "color": "#C62828",
        "fontSize": 10,
        "fontWeight": "bold"
      },
      "encoding": {
        "x": {"value": 8},
        "y": {"datum": 240000},
        "text": {"field": "label"}
      }
    }
  ],
  "config": {
    "title": {"font": "Open Sans", "fontSize": 14, "fontWeight": "bold"},
    "axis": {"labelFont": "Open Sans", "titleFont": "Open Sans", "labelFontSize": 11},
    "legend": {"labelFont": "Open Sans", "titleFont": "Open Sans"},
    "view": {"stroke": "transparent"}
  }
}
