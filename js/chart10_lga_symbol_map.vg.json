{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Actual Approvals vs Estimated Housing Need by Capital City",
    "subtitle": "Bars show actual approvals per 1,000 residents. Orange tick = estimated need (ABS: 2.5 persons/dwelling).",
    "subtitleFontStyle": "italic",
    "subtitleFontSize": 11,
    "subtitleColor": "#666",
    "fontSize": 14,
    "fontWeight": "bold"
  },
  "width": "container",
  "height": 300,
  "data": {"url": "data/gccsa_summary.csv"},
  "transform": [
    {
      "calculate": "datum.city === 'ACT' ? 'Canberra (ACT)' : replace(datum.city_name, 'Greater ', '')",
      "as": "short_name"
    },
    {
      "calculate": "(datum.pop_2025 - datum.pop_2024) / 2.5 / datum.pop_2025 * 1000",
      "as": "need_per_1000"
    },
    {
      "calculate": "datum.approvals_per_1000 - datum.need_per_1000",
      "as": "gap"
    }
  ],
  "layer": [
    {
      "description": "Actual approvals bar",
      "mark": {"type": "bar", "cornerRadiusEnd": 3},
      "encoding": {
        "y": {
          "field": "short_name",
          "type": "nominal",
          "sort": {"field": "gap", "order": "ascending"},
          "title": null,
          "axis": {"labelFontSize": 11}
        },
        "x": {
          "field": "approvals_per_1000",
          "type": "quantitative",
          "title": "Approvals per 1,000 Residents",
          "axis": {"grid": true, "format": ".1f"}
        },
        "color": {
          "condition": {"test": "datum.gap >= 0", "value": "#1976D2"},
          "value": "#c62828"
        },
        "tooltip": [
          {"field": "short_name", "type": "nominal", "title": "City"},
          {"field": "approvals_per_1000", "type": "quantitative", "title": "Actual Approvals (per 1,000)", "format": ".2f"},
          {"field": "need_per_1000", "type": "quantitative", "title": "Estimated Need (per 1,000)", "format": ".2f"},
          {"field": "gap", "type": "quantitative", "title": "Gap (actual − need)", "format": "+.2f"}
        ]
      }
    },
    {
      "description": "Estimated need threshold tick",
      "mark": {"type": "tick", "color": "#FF7043", "thickness": 3, "bandSize": 22, "opacity": 0.9},
      "encoding": {
        "y": {
          "field": "short_name",
          "type": "nominal",
          "sort": {"field": "gap", "order": "ascending"}
        },
        "x": {
          "field": "need_per_1000",
          "type": "quantitative"
        }
      }
    },
    {
      "description": "Actual value label",
      "mark": {"type": "text", "align": "left", "dx": 5, "fontSize": 10, "color": "#444"},
      "encoding": {
        "y": {
          "field": "short_name",
          "type": "nominal",
          "sort": {"field": "gap", "order": "ascending"}
        },
        "x": {"field": "approvals_per_1000", "type": "quantitative"},
        "text": {"field": "approvals_per_1000", "type": "quantitative", "format": ".1f"}
      }
    }
  ],
  "config": {
    "title": {"font": "Open Sans", "fontSize": 14, "fontWeight": "bold"},
    "axis": {"labelFont": "Open Sans", "titleFont": "Open Sans", "labelFontSize": 11},
    "legend": {"labelFont": "Open Sans", "titleFont": "Open Sans"},
    "view": {"stroke": "transparent"}
  }
}
